[Unit]
Description=Iroh DNS Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ iroh_dns_user }}
Group={{ iroh_dns_group }}
Environment="RUST_LOG=info"
Environment="RUST_BACKTRACE=1"
ExecStart={{ iroh_dns_bin_dir }}/iroh-dns-server --config={{ iroh_dns_config_dir }}/config.toml
Restart=on-failure
RestartSec=5
WorkingDirectory={{ iroh_dns_data_dir }}

# Security hardening.
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths={{ iroh_dns_data_dir }} {{ iroh_dns_config_dir }}
ReadOnlyPaths=-/etc/letsencrypt
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
PrivateTmp=true

# Allow binding to privileged ports such as 53 and 443.
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
